# ── Backend (Django) ──────────────────────────────────────────────────────────

# Django security key — generate a long random string for production
SECRET_KEY=your-secret-key-here

# Set to false in production
DEBUG=false

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=yourdomain.onrender.com

# PostgreSQL connection string (auto-set by Render when linked to a database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email / OTP (SendGrid) ────────────────────────────────────────────────────
# SendGrid is the sole email provider. Gmail SMTP is not used.
#
# 1. Create a free account at https://sendgrid.com
# 2. Go to Settings → API Keys → Create API Key (Full Access or Mail Send)
# 3. Verify a sender address or domain under Settings → Sender Authentication
# 4. Add the variables below to the Render dashboard → Environment Variables
#
# Without SENDGRID_API_KEY the server falls back to console mode (dev only —
# OTP codes are printed to the terminal and NOT emailed to users).

SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Must match a verified sender address in your SendGrid account
DEFAULT_FROM_EMAIL=Finance Tracker <you@yourdomain.com>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your deployed frontend URL; leave unset to allow all origins in dev
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# ── Frontend (Vite / React) ───────────────────────────────────────────────────
# Leave empty in development — Vite proxy forwards /api/* to localhost:8000
# Set to your deployed backend URL in production
VITE_API_URL=https://your-backend.onrender.com
