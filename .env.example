# ── Backend (Django) ──────────────────────────────────────────────────────────

# Django security key — generate a long random string for production
SECRET_KEY=your-secret-key-here

# Set to false in production
DEBUG=false

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=yourdomain.onrender.com

# PostgreSQL connection string (auto-set by Render when linked to a database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email / OTP ───────────────────────────────────────────────────────────────
# IMPORTANT: These must be set in the Render dashboard under
# Environment → Environment Variables for OTP emails to work in production.
#
# Do NOT use your normal Gmail password.
# Generate a Gmail App Password at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
#
# Leave EMAIL_HOST_PASSWORD empty in dev to print OTPs to the terminal console.

EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Finance Tracker <your@gmail.com>

# Set to true only if your provider requires SSL (port 465) instead of TLS (port 587)
EMAIL_USE_SSL=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your deployed frontend URL; leave unset to allow all origins in dev
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# ── Frontend (Vite / React) ───────────────────────────────────────────────────
# Leave empty in development — Vite proxy forwards /api/* to localhost:8000
# Set to your deployed backend URL in production
VITE_API_URL=https://your-backend.onrender.com
