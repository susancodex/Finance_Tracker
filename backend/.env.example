# Django Security
SECRET_KEY=generate-a-long-random-string-here
DEBUG=false
ALLOWED_HOSTS=.onrender.com

# Database (auto-set by Render when using a Render PostgreSQL database)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email (Gmail SMTP)
EMAIL_BACKEND=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# CORS — set to your Render frontend URL after deploying the frontend
CORS_ALLOWED_ORIGINS=https://finance-tracker-frontend.onrender.com
